{
  "name": "backend",
  "version": "1.0.0",
  "description": "Cloud kitchen backend",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "seed:categories": "ts-node-dev --transpile-only --no-notify src/scripts/seed-categories.ts",
    "seed:restaurants": "ts-node-dev --transpile-only --no-notify src/scripts/seed-restaurants.ts",
    "create:admin": "ts-node-dev --transpile-only --no-notify src/scripts/create-admin.ts",
    "verify:admin": "ts-node-dev --transpile-only --no-notify src/scripts/verify-admin.ts",
    "rename:admin-email": "ts-node-dev --transpile-only --no-notify src/scripts/rename-admin-email.ts"
  },
  "keywords": [
    "cloud-kitchen",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
